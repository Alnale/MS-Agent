{
  "version": "1.3.0",
  "description": "Main Agent + Sub Agent 系统配置（分离式 Sub Agent 架构）",

  "memory": {
    "enabled": true,
    "working_memory_limit": 50,
    "short_term_ttl_secs": 86400,
    "compression_threshold": 20,
    "retrieval_limit": 20,
    "similarity_threshold": 0.7,
    "daily_decay_factor": 0.95,
    "duplicate_similarity_threshold": 0.92,
    "working_memory_max_tokens": 120000,
    "decay_halflife_days": 7.0,
    "enable_contradiction_detection": true,
    "embedding_cache_size": 10000,
    "session_cache_ttl_secs": 60,
    "hot_cache_max_size": 500
  },

  "unified_cache": {
    "enable_unified_bus": true,
    "hot_cache_capacity": 100,
    "warm_cache_capacity": 500,
    "shared_cache_capacity": 2000,
    "default_cache_mode": "read_write",
    "always_sync_memories": true,
    "default_ttl_secs": 3600,
    "session_timeout_secs": 86400,
    "cleanup_interval_secs": 600,
    "enable_cross_session_cache": true
  },

  "providers": {
    "anthropic": {
      "base_url": "${ANTHROPIC_BASE_URL}",
      "api_key": "${ANTHROPIC_API_KEY}",
      "default_model": "${DEFAULT_MODEL}",
      "timeout_ms": 300000,
      "max_retries": 3,
      "retry_base_delay_ms": 1000,
      "circuit_breaker_threshold": 5,
      "circuit_breaker_open_duration_secs": 10
    },
    "openai": {
      "base_url": "${OPENAI_BASE_URL:-https://api.xiaomimimo.com/v1}",
      "api_key": "${OPENAI_API_KEY}",
      "default_model": "${OPENAI_MODEL:-mimo-v2.5-pro}",
      "timeout_ms": 300000,
      "max_retries": 3,
      "retry_base_delay_ms": 1000,
      "circuit_breaker_threshold": 5,
      "circuit_breaker_open_duration_secs": 10
    },
    "openai_responses": {
      "base_url": "${OPENAI_RESPONSES_BASE_URL:-https://api.xiaomimimo.com/v1}",
      "api_key": "${OPENAI_RESPONSES_API_KEY}",
      "default_model": "${OPENAI_RESPONSES_MODEL:-mimo-v2.5-pro}",
      "timeout_ms": 300000,
      "max_retries": 3,
      "retry_base_delay_ms": 1000,
      "circuit_breaker_threshold": 5,
      "circuit_breaker_open_duration_secs": 10
    }
  },

  "main_agent": {
    "id": "main_agent",
    "thinking": {
      "enabled": true,
      "budget_tokens": 16384,
      "strategy": "Auto"
    },
    "critic": {
      "enabled": true,
      "max_refinement_rounds": 1,
      "thinking": {
        "enabled": false,
        "budget_tokens": 16384,
        "strategy": "Auto"
      }
    },
    "plan_cache": {
      "ttl_secs": 300,
      "capacity": 500
    },
    "total_timeout_ms": 300000,
    "config": {
      "max_tokens": 128000,
      "temperature": 0.7
    }
  },

  "sub_agents": {
    "sentiment": {
      "expertise": "情感分析专家：深入分析用户情绪状态、语气特征、紧迫程度、情感变化趋势",
      "message_types": ["sentiment_analysis", "user_input"],
      "requires_llm": true,
      "priority": 70,
      "optional": false,
      "config": { "max_tokens": 16384, "temperature": 0.1 },
      "thinking": { "enabled": true, "budget_tokens": 4000, "strategy": "Auto" }
    },
    "task_planner": {
      "expertise": "任务规划与工具执行专家：分析请求意图、规划工具调用、执行工具、决定路由",
      "message_types": ["routing_decision", "task_planning", "user_input", "tool_request", "tool_planning", "tool_execution", "file_operation", "web_request", "browser_automation"],
      "requires_llm": true,
      "priority": 110,
      "optional": false,
      "config": { "max_tokens": 65536, "temperature": 0.2 },
      "thinking": { "enabled": true, "budget_tokens": 8000, "strategy": "Auto" }
    },
    "summary": {
      "expertise": "对话摘要、关键信息提取、记忆压缩",
      "message_types": ["conversation_summary"],
      "requires_llm": true,
      "priority": 50,
      "optional": true,
      "config": { "max_tokens": 32768, "temperature": 0.3 },
      "thinking": { "enabled": false, "budget_tokens": 0, "strategy": "Auto" }
    }
  },

  "pipeline": {
    "stages": [
      {
        "name": "baseline",
        "mode": "Parallel",
        "agent_ids": ["sentiment"],
        "timeout_ms": 30000,
        "required": true
      },
      {
        "name": "task_planner_routed",
        "mode": "Parallel",
        "agent_ids": [],
        "timeout_ms": 300000,
        "required": false,
        "description": "Dynamically populated by task_planner's routing decision"
      },
      {
        "name": "respond",
        "mode": "Sequential",
        "agent_ids": ["main_agent"],
        "timeout_ms": 300000,
        "required": true
      }
    ],
    "total_timeout_ms": 300000
  },

  "runtime": {
    "port": 3000,
    "host": "0.0.0.0",
    "log_level": "info",
    "cors_enabled": true,
    "cors_allowed_origins": ["http://localhost:3000", "http://localhost:5173"],
    "max_concurrent_requests": 100,
    "rate_limit_max_requests": 60,
    "rate_limit_window_secs": 60
  },

  "features": {
    "streaming": true,
    "thinking": true,
    "critic": true,
    "caching": true,
    "hot_reload": true,
    "grpc": false
  },

  "external_tools": [],

  "presets": {
    "builtin": [
      {
        "id": "catgirl",
        "name": "小猫娘",
        "icon": "🐱",
        "description": "香香软软的小猫娘，说话带喵~",
        "system_instructions": [
          "你是一只可可爱爱香香软软的小猫娘",
          "你喜欢用可爱的语气说话，经常在句尾加上'喵~'",
          "你的名字叫小咪"
        ]
      },
      {
        "id": "programmer",
        "name": "编程猫",
        "icon": "💻",
        "description": "精通编程的技术专家",
        "system_instructions": [
          "你是一只会编程的猫，精通各种编程语言和技术栈",
          "你喜欢用简洁清晰的方式解释技术问题",
          "回答问题时会给出代码示例"
        ]
      },
      {
        "id": "storyteller",
        "name": "故事大王",
        "icon": "📖",
        "description": "擅长讲故事的叙述者",
        "system_instructions": [
          "你是一个擅长讲故事的人，善于用生动的语言描述场景",
          "你会根据用户的兴趣即兴创作故事"
        ]
      }
    ]
  }
}
